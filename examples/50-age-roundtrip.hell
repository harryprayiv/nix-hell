#!/usr/bin/env nix-hell
main = do
  pubkey <- Text.readFile "test.pub"
  let plaintext = "hello secret world"
  ciphertext <- Age.encrypt (Text.strip pubkey) plaintext
  Text.putStrLn "encrypted successfully"
  secret <- Age.decrypt "/tmp/test.key" ciphertext
  let recovered = Secret.toEnvValue secret
  if Eq.eq recovered plaintext
    then Text.putStrLn "PASS: roundtrip succeeded"
    else Exit.die ("FAIL: got " <> recovered)